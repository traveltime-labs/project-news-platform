# ============================================================
# 前端環境變數（VITE_ 開頭，會暴露在瀏覽器端）
# ============================================================

# Vercel Serverless Function 基底 URL（本地開發留空，由 Vite proxy 轉發）
VITE_API_BASE_URL=

# ============================================================
# 後端環境變數（Vercel Serverless Functions 使用，不加 VITE_ 前綴）
# 本地開發：放在 .env.local
# 正式部署：在 Vercel Dashboard → Settings → Environment Variables 設定
# ============================================================

# Google Service Account（讀寫 Google Sheets）
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
GOOGLE_SHEET_ID=your_google_sheet_id

# OpenAI（按需翻譯）
OPENAI_API_KEY=sk-...

# Telegram（由 GitHub Actions 的 crawler 使用，Vercel 不需要）
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

